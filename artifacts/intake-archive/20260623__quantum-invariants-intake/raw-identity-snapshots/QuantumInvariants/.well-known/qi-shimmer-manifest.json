    "scope": ["P1", "P2", "P3", "P4", "P5", "P6", "P7", "P8", "P9", "P10"]
  },
  "projection_source": {
    "path": "/downloads/20260610__QUANTUMINVARIANTS__DATA__SHIMMER__P1-P10__V0.1__semantic-projections.json",
    "schema": "/downloads/qi-semantic-shimmer.schema.json"
  },
  "seed": {
    "prefix": "#shimmer=qi:v1:",
    "encoding": "kv-semicolon",
    "example": "#shimmer=qi:v1:level=plain;lens=ai;mode=diagnose;focus=diagnostics;compression=flashcard"
