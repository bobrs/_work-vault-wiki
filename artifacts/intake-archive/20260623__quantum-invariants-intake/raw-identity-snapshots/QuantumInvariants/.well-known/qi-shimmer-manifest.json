    {
      "id": "lens",
      "label": "Lens",
      "type": "select",
      "default": "general",
      "options": ["general", "ai", "software", "organization", "family"]
    },
    {
      "id": "mode",
      "label": "Use for",
      "type": "select",
      "default": "learn",
      "options": ["learn", "diagnose", "design", "audit"]
    },
    {
      "id": "focus",
      "label": "Focus",
      "type": "select",
      "default": "all",
      "options": ["direct", "mirror", "shadow", "diagnostics", "all"]
    },
    {
      "id": "compression",
      "label": "Compression",
      "type": "select",
      "default": "full",
      "options": ["one_line", "flashcard", "full"]
    }
  ],
  "ui_copy": {
    "panel_title": "Semantic Shimmer",
